  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading override",
      "info": "Leave blank to use the title configured in the Team Orders app settings"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text override",
      "info": "Leave blank to use the intro configured in the Team Orders app settings"
    }
  ],
  "presets": [
    {
      "name": "Team Orders — Weekly Catering"
    }
  ]
}
{% endschema %}
